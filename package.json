{
  "name": "deepay-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check-build": "node -e \"const fs=require('fs');const files=['dist/assets/app.js','dist/assets/index.css','dist/assets/manifest.json'];let ok=true;files.forEach(f=>{if(!fs.existsSync(f)){console.error('MISSING: '+f);ok=false;}else{console.log('OK: '+f);}});if(!ok)process.exit(1);\""
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.7.2",
    "vite": "^6.3.2"
  }
}
